#! /bin/sh

# x11
# xrandr --output DVI-D-0 --mode 1920x1080 --output HDMI-0 --mode 1366x768 --right-of DVI-D-0
xwallpaper --zoom ~/media/pics/wallpapers/20.png
# xwallpaper --zoom ~/media/pics/wallpapers/plato.png
# xsetroot -solid "#020204"
xrdb ~/.config/x11/xresources
xmodmap ~/.config/x11/xmodmap
xsetroot -cursor_name left_ptr

# moue, keyboard, bell
xset m 20/10 10
xset r rate 300 30
xset b on
# screen saver and dpms
xset s blank
xset s on
xset s 300 300
# xset s noexpose
xset dpms 300 0 0
setxkbmap -layout us,ara -option 'grp:alt_shift_toggle' &
# setxkbmap -layout us
# /usr/share/X11/xkb/rules/base.lst

# ssh-agent


# once
# reload


# launch
# xsettingsd &
wmname LG3D
mpd &
mpDris2 &
urserver start &
# pkill replay-sorcery; replay-sorcery &
# replay-sorcery &
# lf -server &
# pcmanfm -d &

# Kill and Respawn
# pkill syncthing-gtk; syncthing-gtk -m &
pkill barriers; barriers -f -c .config/barrier/config.conf --disable-crypto &
pkill sxhkd; sxhkd &
pkill unclutter; unclutter --timeout 3 --jitter 10 --ignore-scrolling &
pkill dunst; dunst &
# pkill twmnd; twmnd &
# pkill dzen2; ~/.config/dzen2/config &
# pkill xmobar; xmobar ~/.config/xmobar/xmobarrc
pkill polybar; polybar main &
# pkill lemon_launcher; pkill lemonbar; ~/.config/lemonbar/lemon_launcher &
# pkill yambar; yambar &

# cat /tmp/scratchterm_pid | xargs kill
# bspwm-scratch-term init > /tmp/scratchterm_pid

# pkill yambar; yambar &
# picom=~/sectors/c/picom/build/src/picom
# pkill picom; $picom -bfCG --vsync --config "$HOME/.config/picom/picom.conf" --experimental-backends &
# pkill picom; picom --experimental-backends &
pkill picom; picom --experimental-backends &
# pkill picom; picom-epic-animations --experimental-backends &
pkill flashfocus; flashfocus &

# Tray
nm-applet &
pkill udiskie; udiskie -asm nested &
# pkill volumeicon; volumeicon &
# pkill volctl; volctl &
# pkill cbatticon; cbatticon -n &
