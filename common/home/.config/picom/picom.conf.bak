#-bCG

backend = "glx";
vsync = true;
refresh_rate = 60;
use-damage = true;

xrender-sync-fence = true;
glx-no-stencil = true;
glx-no-rebind-pixmap = true;

use-ewmh-active-win = true;
unredir-if-possible = true;
detect-transient = true;
#detect-client-leader = true;


#Dim
#inactive-dim = 0.3

#Shadow
shadow = true
shadow-radius = 30
shadow-offset-x = -30
shadow-offset-y = -30
shadow-opacity = 0.5
xinerama-shadow-crop = true
shadow-exculde = [
"class_g = 'firefox'"
]
#"class_g = 'Firefox' && window_type = 'utility'"
#shadow-exculde = ["name = 'telegram-desktop'"]


# Fade
fading = true
fade-in-step = 0.1
fade-out-step = 0.1
no-fading-destroyed-argb = true

# Opacity
# inactive-opacity = 0.85
# detect-client-opacity = true;
# focus-exclude = [
# "name = 'rofi'",
# ]

# Blur
# blur-method = "gaussian";
# blur-size = 10;
# blur-deviation = 4.0;
# blur-background-exclude = [
# "name = 'slop'",
# "window_type = 'dock'"
# ];


#glx-fshader-win = "/path/to/glsl_shader";
#force-win-blend




# Forkes Options

# Rounded Corners
# round-borders = 5;
# corner-radius = 5;
# rounded-corners-exclude = [
# "class_g = 'polybar'",
# "window_type = 'dock'",
# "name = 'twmn'"
# ];

# Transitions
transition-length = 100
transition-pow-x = 1.0
transition-pow-y = 1.0
transition-pow-w = 0.0
transition-pow-h = 0.0
#size-transition = false



