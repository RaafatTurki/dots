#!/bin/bash

GARBAGE=(
  .ICEauthority
  .anydesk
  .cache
  .cinnamon
  .degit
  .dotnet
  .eclipse
  .flutter
  .gtkrc-2.0
  .icons
  .java
  .lesshst
  .mono
  .npm
  .nuget
  .pki
  .pnpm-debug.log
  .pulse-cookie
  .stack
  .steampath
  .steampid
  .subversion
  .swt
  .synergy
  .thumbnails
  .urserver
  .viminfo
  .wget-hsts
  .wine
  .yarn
  .yarnrc
  unity.lock
  yarn.lock
)

for t in ${GARBAGE[@]}; do
  target=$HOME/$t

  # rm file if exists
  if [ -e $target ]; then
    trash -r $target
    echo $t
  fi

  # rm file if symlink
  if [ -L $target ]; then
    trash -r $target
    echo $t
  fi
done

