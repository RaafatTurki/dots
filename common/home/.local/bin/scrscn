#! /bin/sh

#maim -s | tee >(xclip -selection clipboard -t image/png) ~/$(date +%s).png | curl -F "file=@-" 0x0.st | xclip -selection primary

# Dependencies
#maim
#xclip

#tesseract
#tesseract-date-eng
#zbar

# Vars
ss_save_path=$HOME/media/pics/screenshots/
temp_path=/tmp/screenshot/

ss_file=screen
ss_ex=png
ss_path=$temp_path/$ss_file.$ss_ex
ss_suffix=_`date +%s`

# ocr_file=ocr_res
# ocr_ex=txt
# ocr_path=$temp_path/$ocr_file.$ocr_ex
#
# decode_file=decode_res
# decode_ex=txt
# decode_path=$temp_path/$decode_file.$decode_ex

# Pre
mkdir -p $temp_path
mkdir -p $ss_save_path

# Functions
take_ss() {
    rm $ss_path
    maim --hidecursor --quality 1 -s --bordersize 9999 --shader block $ss_path

    # beep is screenshot taken
    if [ -f $ss_path ]; then
      echo -e "\a"
    fi
}

copy_ss() {
    cat $ss_path | xclip -selection clipboard -t image/png
    cat $ss_path | xclip -t image/png
}

save_ss() {
    cp $ss_path $ss_save_path/$ss_file$ss_suffix.$ss_ex
}

ocr() {
    tesseract -l eng $temp_path/screen.png $temp_path/$ocr_file > /dev/null
#    tesseract -l rus $temp_path/screen.png $temp_path/$ocr_file > /dev/null
#    tesseract -l ara $temp_path/screen.png $temp_path/$ocr_file > /dev/null
}

copy_ocr_res() {
    head -n -1 $ocr_path | xclip -selection clipboard
    head -n -1 $ocr_path | xclip
}

decode() {
    zbarimg -q --raw $temp_path/screen.png > $decode_path
}

copy_decode_res() {
    cat $decode_path | xclip -selection clipboard
    cat $decode_path | xclip
}

clear_temp() {
    rm $ss_path
#    rm $ocr_path
#    rm $decode_path
}




clip() {
  take_ss
  copy_ss
  # clear_temp
}

save() {
  take_ss
  copy_ss
  save_ss
  clear_temp
}

qr() {
  echo "qr here"
#     take_ss
#     decode
#     copy_decode_res
}

bar() {
  echo "bar here"
}

ocr() {
  echo "ocr here"
#     take_ss
#     ocr
#     copy_ocr_res
}


help() {
	cat <<-EOF
Usage: scrscn COMMAND [ARGS...]

Commands:

    cb                ...
    file              ...
    qr                ...
    bar               ...
    ocr               ...
EOF
}

default() {
  clip
}

main() {
  if [ $# -eq 0 ]; then
    default
    return 0
  fi

  cmd="$1"
  shift

  case "$cmd" in
    clip|save|help)
      "$cmd" "$@"
      ;;
    *)
      echo "Unknown command $cmd"
      help
      return 2
  esac
}

main "$@"
