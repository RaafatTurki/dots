#!/usr/bin/bash

GARBAGE=(
# .desktop files
~/.local/share/applications/wine*

# mime types
~/.local/share/mime/packages/x-wine*
~/.local/share/applications/wine-extension*
~/.local/share/icons/hicolor/*/*/application-x-wine-extension*
~/.local/share/mime/application/x-wine-extension*
)

for p in ${GARBAGE[@]}; do
    if [ -e $p ]; then
        trash -r $p
        echo "$p"
    fi
    if [ -L $p ]; then
        trash -r $p
        echo "$p"
    fi
done

